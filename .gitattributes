* text=auto

*.h text eol=lf
*.cpp text eol=lf
*.md text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.usda text eol=lf
*.ply text eol=lf

# Binary fixtures override the general PLY text policy. Binary fixture names
# always end in -binary-le so new ones are covered without a new rule.
plugins/gaussian-ply/tests/fixtures/*-binary-le.ply -text

# Corpus assets are always binary little-endian PLY.
plugins/gaussian-ply/tests/corpus/**/*.ply -text

# Cross-format equivalence pairs; the PLY side is binary little-endian too.
tests/equivalence/fixtures/*.ply -text

# SPZ containers are gzip members (or deliberately damaged fragments of
# them); never treat them as text.
*.spz -text
